---
import "@/styles/global.css";

interface Props {
  title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#2B2A28" />
    <meta
      name="description"
      content="顔出し・声出しゼロで資産化するライフスタイルブランドのAI運営OS — Vlog管制室"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icons/icon-192.svg" />
    <title>{title} | Vlog管制室</title>
    <script is:inline>
      // Avoid a light-mode flash before React hydrates.
      const stored = localStorage.getItem("vlog-control-room:theme");
      const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      if (stored === "dark" || (!stored && prefersDark)) {
        document.documentElement.classList.add("dark");
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
