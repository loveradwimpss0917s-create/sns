{
  "name": "vlog-control-room",
  "private": true,
  "version": "0.1.0",
  "description": "Vlog管制室 — faceless lifestyle vlog AI operations OS (YouTube / Instagram / TikTok)",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter @vlog/web dev",
    "build": "pnpm --filter @vlog/web build",
    "preview": "pnpm --filter @vlog/web preview",
    "lint": "eslint . --ext .ts,.tsx,.astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:generate": "pnpm --filter @vlog/database generate",
    "db:migrate:local": "pnpm --filter @vlog/database migrate:local",
    "db:seed": "tsx scripts/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "astro-eslint-parser": "^1.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
